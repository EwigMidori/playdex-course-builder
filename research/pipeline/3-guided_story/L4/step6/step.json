      "lines": [
        "有没有一个数字，能直接告诉我们市场是什么状态？",
        "有——<term id=\"hurst_exponent\">Hurst指数</term>。"
      ],
      "type": "narration"
    },
    {
      "focus_terms": [
        "hurst_exponent"
      ],
      "id": "s038",
      "introduced_terms": [],
      "lines": [
        "H = 0.5 → 随机游走",
        "H < 0.5 → 均值回归",
        "H > 0.5 → 趋势"
      ],
      "type": "narration"
    },
    {
      "focus_terms": [
        "hurst_exponent"
      ],
      "id": "s039",
      "introduced_terms": [],
      "lines": [
        "H越接近0，均值回归越强；",
        "H越接近1，趋势越强。"
      ],
      "type": "narration"
    },
    {
      "focus_terms": [
        "half_life"
      ],
