      "lines": [
        "常用指标是 <term id=\"sse\">误差平方和</term>。",
        "它计算每个点到其簇质心的距离，然后平方求和。"
      ],
      "type": "narration"
    },
    {
      "focus_terms": [],
      "formula": {
        "latex": "\\text{SSE} = \\sum_{i=1}^{K} \\sum_{x \\in C_i} \\text{dist}(x, m_i)^2",
