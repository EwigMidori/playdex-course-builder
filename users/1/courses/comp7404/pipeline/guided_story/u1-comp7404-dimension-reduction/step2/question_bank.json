      "variants": [
        {
          "estimated_seconds": 90,
          "prompt_blocks": [
            "流形学习的基本假设",
            "降维的目标",
            "与投影的区别"
          ],
          "question_id": "q_long_manifold_goal_v1",
          "reference_answer": [
            "流形学习假设高维数据实际上位于一个低维流形（曲面）上。",
            "它的目标不是简单地将数据投影到低维平面，而是恢复这个曲面的内在坐标，即找到数据在低维流形上的真实表示。",
            "与投影的根本区别在于：投影是线性操作，会破坏非线性结构（如瑞士卷的不同层会被压在一起）；而流形学习旨在保持数据的非线性结构，将其“展开”到低维空间。"
          ],
          "rubric_points": [
            "提到流形学习假设高维数据位于低维流形上",
            "提到目标是恢复这个流形的内在坐标",
            "提到投影是直接压到低维平面，而流形学习是恢复曲面结构"
          ],
          "stem": "请用自己的话解释：流形学习的目标是什么？它与简单的投影有什么根本不同？"
        },
        {
          "estimated_seconds": 90,
          "prompt_blocks": [
            "瑞士卷数据的结构特点",
            "线性投影失败的原因",
            "流形学习的解决思路"
          ],
          "question_id": "q_long_manifold_goal_v2",
          "reference_answer": [
            "瑞士卷数据虽然看起来是三维的，但其本质是一个二维曲面卷曲而成的。",
            "线性投影（如PCA）会直接将数据压到二维平面上，导致不同卷层的点被压在一起，无法区分。",
            "流形学习假设数据位于一个低维流形上，降维的目标是恢复这个曲面的内在坐标，从而将卷曲的瑞士卷“展开”成平坦的二维结构。"
          ],
          "rubric_points": [
            "提到瑞士卷是卷曲的二维曲面",
            "提到线性投影会压扁不同层",
            "提到流形学习假设数据在低维流形上，目标是恢复内在坐标"
          ],
          "stem": "以瑞士卷数据为例，说明为什么线性投影会失败，以及流形学习是如何解决这个问题的。"
        }
      ]
    }
