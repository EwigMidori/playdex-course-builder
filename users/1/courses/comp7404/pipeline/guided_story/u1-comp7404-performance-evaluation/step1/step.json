      ],
      "lines": [
        "模型预测为负类，实际也是负类 → <term id=\"true_negative\">真负例</term>（TN）。",
        "模型预测为负类，实际是正类 → <term id=\"false_negative\">假负例</term>（FN）。"
      ],
      "type": "narration"
    },
