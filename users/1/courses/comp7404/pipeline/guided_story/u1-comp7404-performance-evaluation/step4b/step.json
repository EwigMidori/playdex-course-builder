      "type": "narration"
    },
    {
      "focus_terms": [
        "auc"
      ],
      "id": "s052",
      "introduced_terms": [],
      "lines": [
        "AUC = 1 表示完美分类器。",
        "AUC = 0.5 表示随机猜测，毫无预测能力。"
      ],
      "type": "narration"
    },
