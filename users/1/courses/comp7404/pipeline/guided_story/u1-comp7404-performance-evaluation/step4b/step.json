      "introduced_terms": [
        "auc"
      ],
      "lines": [
        "ROC 曲线越靠近左上角，模型性能越好。",
        "为了量化这个“好”的程度，我们引入 <term id=\"auc\">AUC</term>。"
      ],
      "type": "narration"
